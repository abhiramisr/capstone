# Copy to .env and fill in values.
# cp .env.example .env

# Required for the full agent pipeline (src.app, orchestrator)
OPENAI_API_KEY=

# Optional — Azure OpenAI / Foundry (if you use src/connectors/azure_openai_connector.py)
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=
# OPENAI_API_VERSION=

# Optional — Microsoft Fabric Warehouse (ODBC + service principal).
# When set, the pipeline uses Fabric (T-SQL) instead of DuckDB + CSV.
# Either set FABRIC_CONNECTION_STRING alone, OR all of the following:
# FABRIC_SERVER=
# FABRIC_DATABASE=
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# FABRIC_CONNECTION_STRING=
# FABRIC_ODBC_DRIVER=ODBC Driver 18 for SQL Server
